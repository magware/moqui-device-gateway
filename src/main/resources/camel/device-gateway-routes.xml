<routes xmlns="http://camel.apache.org/schema/xml-io">
    <!--
        MQTT consumer entrypoint.
        Receives device-originated JSON messages from the configured broker endpoint and
        forwards them directly to the MQTT inbound ingestion route.
        In this gateway `read` means "receive/ingest inbound data", not "perform an MQTT subscribe call"
        on demand for a single request.
    -->
    <route id="mqtt-read-device-request-consumer" autoStartup="{{mqtt.read.route.autoStartup}}">
        <from uri="{{mqtt.read.consume.uri}}"/>
        <doTry>
            <convertBodyTo type="java.lang.String"/>
            <unmarshal>
                <json library="Jackson"/>
            </unmarshal>
            <to uri="direct:mqtt-read-device-request"/>
            <doCatch>
                <exception>java.lang.Exception</exception>
                <log message="Discarding MQTT consumer payload after runtime failure: ${exception.message}" loggingLevel="WARN"/>
            </doCatch>
        </doTry>
    </route>

    <!--
        OPC UA consumer entrypoint.
        Defaulted to SEDA and disabled until an OPC UA endpoint is configured.
        This static route expects JSON payloads shaped like the MQTT path; real live OPC UA
        subscriptions are normally registered dynamically by GatewayRequestService.
        As with MQTT, `read` here means inbound ingest, not a one-shot protocol read operation.
    -->
    <route id="opcua-read-device-request-consumer" autoStartup="{{opcua.read.route.autoStartup}}">
        <from uri="{{opcua.read.consume.uri}}"/>
        <doTry>
            <convertBodyTo type="java.lang.String"/>
            <unmarshal>
                <json library="Jackson"/>
            </unmarshal>
            <to uri="direct:opcua-read-device-request"/>
            <doCatch>
                <exception>java.lang.Exception</exception>
                <log message="Discarding OPC UA consumer payload after runtime failure: ${exception.message}" loggingLevel="WARN"/>
            </doCatch>
        </doTry>
    </route>

    <!--
        MQTT inbound ingestion route.
        Adds MQTT-specific route properties and delegates persistence semantics to the
        common inbound storage route.
        It is used both by the static MQTT consumer and by dynamically registered subscribe routes.
    -->
    <route id="mqtt-read-device-request">
        <from uri="direct:mqtt-read-device-request"/>
        <setProperty name="protocolLabel">
            <constant>MQTT</constant>
        </setProperty>
        <setProperty name="storeLogUri">
            <simple>{{mqtt.read.store.log.uri}}</simple>
        </setProperty>
        <setProperty name="storeParameterUri">
            <simple>{{mqtt.read.store.parameter.uri}}</simple>
        </setProperty>
        <setProperty name="afterStoreEnabled">
            <simple>{{mqtt.read.afterStore.enabled}}</simple>
        </setProperty>
        <setProperty name="afterStoreUri">
            <simple>{{mqtt.read.afterStore.uri}}</simple>
        </setProperty>
        <to uri="direct:store-device-request-inbound"/>
    </route>

    <!--
        Shared inbound storage route for normalized device payloads.
        Persists incoming values into ParameterLog or Parameter depending on
        DeviceRequest purpose semantics, independent from the transport protocol.
    -->
    <route id="store-device-request-inbound">
        <from uri="direct:store-device-request-inbound"/>
        <setBody>
            <groovy>body instanceof java.util.List ? body : [body]</groovy>
        </setBody>
        <setProperty name="inboundPayload">
            <groovy>body</groovy>
        </setProperty>
        <setProperty name="purposeEnumId">
            <groovy>body ? body[0]?.purposeEnumId : null</groovy>
        </setProperty>
        <choice>
            <!-- Non-logging purpose: upsert current logical state in PARAMETER -->
            <when>
                <simple>${exchangeProperty.purposeEnumId} != null &amp;&amp; ${exchangeProperty.purposeEnumId} != 'DrpLogging'</simple>
                <setBody>
                    <groovy>body.collect { row -> [parameterId: row.parameterId, numericValue: row.numericValue, symbolicValue: row.symbolicValue, parameterEnumId: row.parameterEnumId] }</groovy>
                </setBody>
                <doTry>
                    <toD uri="${exchangeProperty.storeParameterUri}"/>
                    <doCatch>
                        <exception>java.lang.Exception</exception>
                        <log message="Discarding ${exchangeProperty.protocolLabel} inbound payload after DB write failure: ${exception.message}" loggingLevel="WARN"/>
                        <to uri="bean:inboundErrorNotifier?method=recordError"/>
                        <stop/>
                    </doCatch>
                </doTry>
            </when>
            <!-- Logging (or missing purpose): persist telemetry snapshot in PARAMETER_LOG -->
            <otherwise>
                <setBody>
                    <groovy>body.withIndex().collect { row, i -> [parameterLogId: (row.parameterLogId ?: java.util.UUID.randomUUID().toString()), sequenceNum: System.currentTimeMillis() + i, parameterId: row.parameterId, observedDate: row.observedDate, numericValue: row.numericValue, symbolicValue: row.symbolicValue, parameterEnumId: row.parameterEnumId] }</groovy>
                </setBody>
                <doTry>
                    <toD uri="${exchangeProperty.storeLogUri}"/>
                    <doCatch>
                        <exception>java.lang.Exception</exception>
                        <log message="Discarding ${exchangeProperty.protocolLabel} inbound payload after DB write failure: ${exception.message}" loggingLevel="WARN"/>
                        <to uri="bean:inboundErrorNotifier?method=recordError"/>
                        <stop/>
                    </doCatch>
                </doTry>
            </otherwise>
        </choice>
        <to uri="bean:inboundErrorNotifier?method=clearError"/>
        <setBody>
            <groovy>exchange.properties.inboundPayload</groovy>
        </setBody>
        <choice>
            <when>
                <simple>${exchangeProperty.afterStoreEnabled} == 'true'</simple>
                <doTry>
                    <toD uri="${exchangeProperty.afterStoreUri}" pattern="InOnly"/>
                    <doCatch>
                        <exception>java.lang.Exception</exception>
                        <log message="Ignoring ${exchangeProperty.protocolLabel} afterStore callback failure: ${exception.message}" loggingLevel="WARN"/>
                    </doCatch>
                </doTry>
            </when>
        </choice>
    </route>

    <!--
        MQTT write request route.
        Executes outbound logical writes toward MQTT targets.
        The route keeps the historical `write` name because it follows `DeviceRequest` semantics:
        from the business point of view the request writes values to a target device, even if the
        transport-level action is an MQTT publish.
    -->
    <route id="mqtt-write-device-request">
        <from uri="direct:mqtt-write-device-request"/>
        <to uri="bean:gatewayRequestService?method=runMqttWrite"/>
    </route>

    <!--
        MQTT subscribe trigger route.
        Registers per-request dynamic MQTT consumer routes.
        This is the explicit subscribe lifecycle action; the static `mqtt-read-device-request-consumer`
        is instead a preconfigured always-on listener controlled by `autoStartup`.
    -->
    <route id="mqtt-subscribe-device-request">
        <from uri="direct:mqtt-subscribe-device-request"/>
        <to uri="bean:gatewayRequestService?method=subscribeMqtt"/>
    </route>

    <!--
        OPC UA inbound ingestion route.
        Adds OPC UA-specific route properties and delegates persistence semantics to the
        common inbound storage route.
        It is used both by the optional static OPC UA consumer and by dynamically registered
        OPC UA subscribe routes.
    -->
    <route id="opcua-read-device-request">
        <from uri="direct:opcua-read-device-request"/>
        <setProperty name="protocolLabel">
            <constant>OPC UA</constant>
        </setProperty>
        <setProperty name="storeLogUri">
            <simple>{{opcua.read.store.log.uri}}</simple>
        </setProperty>
        <setProperty name="storeParameterUri">
            <simple>{{opcua.read.store.parameter.uri}}</simple>
        </setProperty>
        <setProperty name="afterStoreEnabled">
            <simple>{{opcua.read.afterStore.enabled}}</simple>
        </setProperty>
        <setProperty name="afterStoreUri">
            <simple>{{opcua.read.afterStore.uri}}</simple>
        </setProperty>
        <to uri="direct:store-device-request-inbound"/>
    </route>

    <!--
        OPC UA write request route.
        Executes outbound logical writes toward OPC UA targets.
        As for MQTT, `write` follows `DeviceRequest` business semantics rather than transport naming.
    -->
    <route id="opcua-write-device-request">
        <from uri="direct:opcua-write-device-request"/>
        <to uri="bean:gatewayRequestService?method=runOpcUaWrite"/>
    </route>

    <!--
        OPC UA subscribe trigger route.
        Registers per-request dynamic OPC UA consumer routes.
        The static `opcua-read-device-request-consumer` is a separate optional listener controlled
        by `autoStartup`; real live OPC UA subscriptions usually come through this route.
    -->
    <route id="opcua-subscribe-device-request">
        <from uri="direct:opcua-subscribe-device-request"/>
        <to uri="bean:gatewayRequestService?method=subscribeOpcUa"/>
    </route>

    <!--
        Canonical DeviceConfig export route.
        Groups DeviceRule rows by PRIORITY within a DeviceRuleSet and writes one
        Codesys txtrecipe file per priority group.
        Filename: {ruleSetName}_p{priority:02d}.txt
        All DeviceRule rows with the same PRIORITY land in the same file; different
        priorities produce separate files so Codesys loads them as distinct recipe steps.
    -->
    <route id="run-device-config-export">
        <from uri="direct:run-device-config-export"/>
        <toD uri="{{device.config.export.fetch.uri}}"/>
        <transform>
            <groovy>body instanceof Map &amp;&amp; body.containsKey('rowList') ? body.rowList : body</groovy>
        </transform>
        <!-- Build one entry per priority group: {filename, content, priority, rowCount} -->
        <transform>
            <groovy><![CDATA[
def rows = body instanceof List ? body : [body]
def ruleSetName = rows ? (rows[0]?.ruleSetName ?: 'recipe') : 'recipe'
rows.groupBy { it['priority'] ?: 0 }
    .sort { a, b -> (a.key as int) <=> (b.key as int) }
    .collect { priority, group ->
        [
            filename : "${ruleSetName}_p${String.format('%02d', priority as int)}.txt",
            content  : group.collect { "${it['parameterName']}:=${it['parameterValue']}" }.join('\n'),
            priority : priority,
            rowCount : group.size()
        ]
    }
            ]]></groovy>
        </transform>
        <setProperty name="exportFileList">
            <groovy>body</groovy>
        </setProperty>
        <!-- Write one file per priority group -->
        <split>
            <simple>${body}</simple>
            <setHeader name="CamelFileName">
                <groovy>body.filename</groovy>
            </setHeader>
            <transform>
                <groovy>body.content</groovy>
            </transform>
            <to uri="direct:transfer-file"/>
        </split>
        <!-- Build response from the saved file list -->
        <setBody>
            <groovy>exchange.properties.exportFileList</groovy>
        </setBody>
        <transform>
            <groovy><![CDATA[
import com.fasterxml.jackson.databind.ObjectMapper
new ObjectMapper().writeValueAsString([
    status  : 'completed',
    routeId : exchange.fromRouteId,
    files   : body.collect { [filename: it.filename, priority: it.priority, rowCount: it.rowCount] }
])
            ]]></groovy>
        </transform>
        <unmarshal>
            <json library="Jackson"/>
        </unmarshal>
    </route>

    <route id="transfer-file">
        <from uri="direct:transfer-file"/>
        <toD uri="{{file.transfer.uri}}" pattern="InOnly"/>
        <choice>
            <when>
                <simple>${properties:file.transfer.uri.2.enabled:false}</simple>
                <toD uri="{{file.transfer.uri.2}}" pattern="InOnly"/>
            </when>
        </choice>
    </route>

    <!-- Device content transfer (G-Code, firmware, CNC programs, etc.).
         CamelFileName and gatewayTransferUri headers are set by GatewayResource. -->
    <route id="transfer-device-content">
        <from uri="direct:transfer-device-content"/>
        <toD uri="${header.gatewayTransferUri}" pattern="InOnly"/>
    </route>

    <!--
        PLC log subscribe trigger route.
        Registers a dynamic MQTT consumer that forwards LoggerFacade batches to
        plc-log-ingest, bypassing the standard parameter normalization used by
        mqtt-subscribe-device-request.
        Triggered by a DeviceRequest with purposeEnumId='DrpLogging' and
        requestTypeEnumId in (DrtSubscribe, DrtEvent, DrtStateChange, DrtCyclic).
        The DeviceRequest.query field must contain the MQTT topic (e.g. 'moqui-plc').
        DeviceRequestItems are not used — the LoggerFacade batch is self-describing.
    -->
    <route id="plc-log-subscribe-device-request">
        <from uri="direct:plc-log-subscribe-device-request"/>
        <to uri="bean:gatewayRequestService?method=subscribePlcLog"/>
    </route>

    <!--
        PLC diagnostic log consumer (CODESYS LoggerFacade batch format).
        Receives batches published by the PLC LoggerFacade MQTT appender and
        forwards them to the plc-log-ingest route for transformation and storage.

        PLC batch format:
          { "1": { "logEventDate": "DT#YYYY-MM-DD-HH:MM:SS",
                   "loggerName": "hvac", "source": "",
                   "type": 0|1|2, "repeatCount": 1,
                   "message": "..."       (type=0 Text)
                   "numericValue": 42.5   (type=1 Numeric)
                   "enumValue": 3         (type=2 Enum) }, "2": {...} }
    -->
    <route id="plc-log-consumer" autoStartup="{{plc.log.route.autoStartup}}">
        <from uri="{{plc.log.consume.uri}}"/>
        <doTry>
            <convertBodyTo type="java.lang.String"/>
            <unmarshal>
                <json library="Jackson"/>
            </unmarshal>
            <to uri="direct:plc-log-ingest"/>
            <doCatch>
                <exception>java.lang.Exception</exception>
                <log message="Discarding PLC log payload after runtime failure: ${exception.message}" loggingLevel="WARN"/>
            </doCatch>
        </doTry>
    </route>

    <!--
        PLC log ingestion route.
        Input: Jackson-decoded Map {"1":{loggerName,logEventDate,type,message|numericValue|enumValue,...},...}

        Routing by source field:
          source non-empty → PARAMETER_LOG via store-device-request-inbound
            parameterId   = loggerName.source
            numericValue  = numericValue (type=1) | null
            symbolicValue = message (type=0) | enumValue as string (type=2) | null
          source empty    → DEVICE_LOG
            deviceId      = loggerName
            payload       = full JSON entry

        Steps for source entries:
          1. Partition batch into withSource / withoutSource lists.
          2. Ensure PlcLoggerDef PARAMETER_DEF row (idempotent).
          3. Ensure PARAMETER rows per unique parameterId (idempotent).
          4. Delegate withSource list to store-device-request-inbound → PARAMETER_LOG.
          5. Write withoutSource list directly to DEVICE_LOG.
        All steps are non-blocking: on error the exchange is discarded and inboundErrorNotifier
        is called, but the route continues processing the next message.
    -->
    <route id="plc-log-ingest">
        <from uri="direct:plc-log-ingest"/>
        <!--
            Outer try: catches Groovy transform errors (malformed batch).
            The two inner paths (withSource / withoutSource) are isolated in their
            own doTry blocks so that a stop() or failure in one does not suppress the other.
        -->
        <doTry>
            <!-- Partition: entries with source → PARAMETER_LOG, entries without → DEVICE_LOG -->
            <transform>
                <groovy><![CDATA[
import java.text.SimpleDateFormat
import com.fasterxml.jackson.databind.ObjectMapper
def sdf    = new SimpleDateFormat("'DT#'yyyy-MM-dd-HH:mm:ss")
def mapper = new ObjectMapper()
def withSource    = []
def withoutSource = []
(body instanceof Map ? body : [:]).values().withIndex().each { entry, i ->
    def ts = null
    try { ts = new java.sql.Timestamp(sdf.parse(entry.logEventDate ?: '').time) } catch(ignored) {}
    def loggerName = entry.loggerName ?: 'plc-log-unknown'
    def source     = entry.source ?: ''
    def type       = entry.type as Integer
    if (source) {
        withSource << [
            parameterId  : "${loggerName}.${source}",
            observedDate : ts,
            numericValue : (type == 1) ? entry.numericValue : null,
            symbolicValue: (type == 2) ? String.valueOf(entry.enumValue) : entry.message,
            purposeEnumId: 'DrpLogging'
        ]
    } else {
        withoutSource << [
            deviceLogId : java.util.UUID.randomUUID().toString(),
            deviceId    : loggerName,
            payload     : mapper.writeValueAsString(entry),
            sequenceNum : System.currentTimeMillis() + i,
            observedDate: ts
        ]
    }
}
[withSource: withSource, withoutSource: withoutSource]
                ]]></groovy>
            </transform>
            <setProperty name="plcLogWithSource">
                <groovy>body.withSource</groovy>
            </setProperty>
            <setProperty name="plcLogWithoutSource">
                <groovy>body.withoutSource</groovy>
            </setProperty>

            <!-- Path A: source entries → PARAMETER_LOG via store-device-request-inbound.
                 Isolated in its own doTry so stop() from store-device-request-inbound
                 cannot suppress Path B below. -->
            <doTry>
                <choice>
                    <when>
                        <groovy>exchange.properties.plcLogWithSource</groovy>
                        <doTry>
                            <to uri="{{plc.log.store.ensure.parameter.def.uri}}"/>
                            <doCatch>
                                <exception>java.lang.Exception</exception>
                                <log message="Could not ensure PlcLoggerDef ParameterDef: ${exception.message}" loggingLevel="WARN"/>
                            </doCatch>
                        </doTry>
                        <setBody>
                            <groovy>exchange.properties.plcLogWithSource.collect { [parameterId: it.parameterId] }.unique { it.parameterId }</groovy>
                        </setBody>
                        <doTry>
                            <toD uri="{{plc.log.store.ensure.parameter.uri}}"/>
                            <doCatch>
                                <exception>java.lang.Exception</exception>
                                <log message="Discarding MQTT-PLC-LOG (source) after PARAMETER upsert failure: ${exception.message}" loggingLevel="WARN"/>
                                <to uri="bean:inboundErrorNotifier?method=recordError"/>
                            </doCatch>
                        </doTry>
                        <setBody>
                            <groovy>exchange.properties.plcLogWithSource</groovy>
                        </setBody>
                        <setProperty name="protocolLabel"><constant>MQTT-PLC-LOG</constant></setProperty>
                        <setProperty name="storeLogUri"><simple>{{mqtt.read.store.log.uri}}</simple></setProperty>
                        <setProperty name="storeParameterUri"><simple>{{mqtt.read.store.parameter.uri}}</simple></setProperty>
                        <setProperty name="afterStoreEnabled"><simple>{{mqtt.read.afterStore.enabled}}</simple></setProperty>
                        <setProperty name="afterStoreUri"><simple>{{mqtt.read.afterStore.uri}}</simple></setProperty>
                        <to uri="direct:store-device-request-inbound"/>
                    </when>
                </choice>
                <doCatch>
                    <exception>java.lang.Exception</exception>
                    <log message="Discarding MQTT-PLC-LOG (source) after unexpected failure: ${exception.message}" loggingLevel="WARN"/>
                    <to uri="bean:inboundErrorNotifier?method=recordError"/>
                </doCatch>
            </doTry>

            <!-- Path B: no-source entries → DEVICE_LOG. Always runs independently of Path A. -->
            <doTry>
                <choice>
                    <when>
                        <groovy>exchange.properties.plcLogWithoutSource</groovy>
                        <setBody>
                            <groovy>exchange.properties.plcLogWithoutSource</groovy>
                        </setBody>
                        <toD uri="{{plc.log.store.device.log.uri}}"/>
                    </when>
                </choice>
                <doCatch>
                    <exception>java.lang.Exception</exception>
                    <log message="Discarding MQTT-PLC-LOG (no source) after DEVICE_LOG write failure: ${exception.message}" loggingLevel="WARN"/>
                    <to uri="bean:inboundErrorNotifier?method=recordError"/>
                </doCatch>
            </doTry>

            <doCatch>
                <exception>java.lang.Exception</exception>
                <log message="Discarding MQTT-PLC-LOG inbound payload after transform failure: ${exception.message}" loggingLevel="WARN"/>
                <to uri="bean:inboundErrorNotifier?method=recordError"/>
            </doCatch>
        </doTry>
    </route>
</routes>
